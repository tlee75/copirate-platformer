; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="copirate-platformer"
run/main_scene="res://scenes/main_scene.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameObjectsDatabase="*res://scripts/systems/game_objects_database.gd"
PlacementManager="*res://scripts/systems/placement_manager.gd"
ResourceManager="*res://scripts/systems/resource_manager.gd"
InventoryManager="*res://scripts/systems/inventory_manager.gd"
PlayerInputHandler="*res://scripts/systems/player_input_handler.gd"
BuildingManager="*res://scripts/systems/building_manager.gd"
CraftingManager="*res://scripts/systems/crafting_manager.gd"

[display]

window/stretch/mode="viewport"
window/stretch/aspect="expand"

[gui]

theme/default_font_multichannel_signed_distance_field=true

